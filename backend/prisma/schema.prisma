generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  BLOCKED
  PENDING_VERIFICATION
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum VehicleCategory {
  ECONOMY
  HATCH
  SEDAN
  SUV
  PICKUP
  VAN
  LUXURY
}

enum VehicleType {
  CAR
  MOTORCYCLE
}

enum MotorcycleStyle {
  SCOOTER
  STREET
  SPORT
  TRAIL
  CUSTOM
  TOURING
}

enum FuelType {
  GASOLINE
  ETHANOL
  FLEX
  DIESEL
  ELECTRIC
  HYBRID
}

enum Transmission {
  MANUAL
  AUTOMATIC
  CVT
}

enum PrivacyRequestType {
  ACCESS
  PORTABILITY
  DELETION
  CORRECTION
  RESTRICTION
  OBJECTION
  ANONYMIZATION
  REVOCATION
}

enum PrivacyRequestStatus {
  OPEN
  IN_REVIEW
  COMPLETED
  REJECTED
  CANCELLED
}

enum NotificationType {
  REVIEW_CREATED
  CHAT_MESSAGE
  SYSTEM_ALERT
}

enum SupportMessageRole {
  USER
  ASSISTANT
}

enum SupportMessageScope {
  SUPPORTED
  NOT_AVAILABLE
  OUT_OF_SCOPE
  HANDOFF
}

enum SupportMessageConfidence {
  LOW
  MEDIUM
  HIGH
}

model User {
  id                        String                @id @default(uuid())
  email                     String                @unique
  passwordHash              String
  role                      Role
  status                    UserStatus            @default(ACTIVE)
  refreshTokenHash          String?
  lastLoginAt               DateTime?
  analyticsConsentGranted   Boolean               @default(false)
  analyticsConsentUpdatedAt DateTime?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  profile                   Profile?
  ownedVehicles             Vehicle[]             @relation("VehicleOwner")
  reviewsWritten            Review[]              @relation("ReviewAuthor")
  reviewsReceived           Review[]              @relation("ReviewOwner")
  userReviewsWritten        UserReview[]          @relation("UserReviewAuthor")
  userReviewsReceived       UserReview[]          @relation("UserReviewTarget")
  notifications             Notification[]
  chatConversations         ChatParticipant[]
  sentChatMessages          ChatMessage[]
  createdChats              ChatConversation[]    @relation("ChatConversationCreator")
  favorites                 Favorite[]
  searchAlerts              SearchAlert[]
  supportConversations      SupportConversation[]
  privacyRequests           PrivacyRequest[]

  @@index([role, status])
}

model Profile {
  id                         String             @id @default(uuid())
  userId                     String             @unique
  fullName                   String
  phone                      String
  zipCode                    String?
  addressLine                String?
  addressComplement          String?
  city                       String
  state                      String
  bio                        String?
  avatarUrl                  String?
  documentNumber             String?
  driverLicenseNumber        String?
  documentImageUrl           String?
  driverLicenseImageUrl      String?
  documentVerificationStatus VerificationStatus @default(NOT_SUBMITTED)
  driverLicenseVerification  VerificationStatus @default(NOT_SUBMITTED)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  user                       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vehicle {
  id                 String             @id @default(uuid())
  ownerId            String
  title              String
  brand              String
  model              String
  year               Int
  plate              String             @unique
  city               String
  state              String
  vehicleType        VehicleType        @default(CAR)
  category           VehicleCategory
  transmission       Transmission
  fuelType           FuelType
  seats              Int
  dailyRate          Decimal            @db.Decimal(10, 2)
  motorcycleStyle    MotorcycleStyle?
  engineCc           Int?
  hasAbs             Boolean?
  hasTopCase         Boolean?
  description        String
  addressLine        String?
  latitude           Decimal?           @db.Decimal(10, 7)
  longitude          Decimal?           @db.Decimal(10, 7)
  isActive           Boolean            @default(true)
  isPublished        Boolean            @default(true)
  ratingAverage      Decimal            @default(0) @db.Decimal(3, 2)
  reviewsCount       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  owner              User               @relation("VehicleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  images             VehicleImage[]
  reviews            Review[]
  chatConversations  ChatConversation[]
  favorites          Favorite[]
  searchAlertMatches SearchAlertMatch[]
  views              VehicleView[]

  @@index([ownerId])
  @@index([city, state, vehicleType, category, isActive, isPublished])
  @@index([dailyRate])
}

model SearchAlert {
  id        String             @id @default(uuid())
  userId    String
  title     String?
  filters   Json
  queryHash String
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches   SearchAlertMatch[]

  @@unique([userId, queryHash])
  @@index([userId, isActive])
}

model SearchAlertMatch {
  id            String      @id @default(uuid())
  searchAlertId String
  vehicleId     String
  notifiedAt    DateTime    @default(now())
  searchAlert   SearchAlert @relation(fields: [searchAlertId], references: [id], onDelete: Cascade)
  vehicle       Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([searchAlertId, vehicleId])
  @@index([vehicleId, notifiedAt])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  vehicleId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId, createdAt])
  @@index([vehicleId])
}

model VehicleImage {
  id        String   @id @default(uuid())
  vehicleId String
  url       String
  key       String
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, position])
}

model Review {
  id        String   @id @default(uuid())
  vehicleId String
  authorId  String
  ownerId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  owner     User     @relation("ReviewOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([vehicleId, rating])
  @@index([ownerId, rating])
}

model UserReview {
  id           String   @id @default(uuid())
  authorId     String
  targetUserId String
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author       User     @relation("UserReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetUser   User     @relation("UserReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, rating])
  @@index([authorId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model ChatConversation {
  id             String            @id @default(uuid())
  vehicleId      String
  createdById    String
  participantKey String            @unique
  lastMessageAt  DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  vehicle        Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy      User              @relation("ChatConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants   ChatParticipant[]
  messages       ChatMessage[]

  @@index([vehicleId, updatedAt])
  @@index([createdById, updatedAt])
}

model ChatParticipant {
  id             String           @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  joinedAt       DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, joinedAt])
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

model SupportConversation {
  id            String           @id @default(uuid())
  userId        String
  title         String
  lastMessageAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      SupportMessage[]

  @@index([userId, updatedAt])
  @@index([userId, lastMessageAt])
}

model SupportMessage {
  id               String                    @id @default(uuid())
  conversationId   String
  role             SupportMessageRole
  content          String
  relatedArea      String?
  scope            SupportMessageScope?
  confidence       SupportMessageConfidence?
  suggestedActions String[]
  disclaimer       String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  conversation     SupportConversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model SiteVisit {
  id           String   @id @default(uuid())
  visitorId    String
  path         String
  referrer     String?
  userAgent    String?
  isFirstVisit Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([visitorId, createdAt])
  @@index([createdAt])
  @@index([isFirstVisit, createdAt])
}

model VehicleView {
  id        String   @id @default(uuid())
  vehicleId String
  visitorId String
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, createdAt])
  @@index([visitorId, vehicleId, createdAt])
  @@index([createdAt])
}

model PrivacyRequest {
  id              String               @id @default(uuid())
  userId          String
  type            PrivacyRequestType
  status          PrivacyRequestStatus @default(OPEN)
  notes           String?
  resolutionNotes String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  completedAt     DateTime?
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
}
