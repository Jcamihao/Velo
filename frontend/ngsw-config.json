{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|png|webp|jpg|jpeg|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "public-catalog",
      "urls": [
        "/api/v1/vehicles",
        "/api/v1/vehicles/**",
        "http://localhost:3002/api/v1/vehicles",
        "http://localhost:3002/api/v1/vehicles/**",
        "http://127.0.0.1:3002/api/v1/vehicles",
        "http://127.0.0.1:3002/api/v1/vehicles/**"
      ],
      "cacheConfig": {
        "maxSize": 40,
        "maxAge": "30m",
        "timeout": "10s",
        "strategy": "freshness"
      }
    },
    {
      "name": "public-content",
      "urls": [
        "/api/v1/privacy/policy",
        "/api/v1/reviews/vehicle/**",
        "http://localhost:3002/api/v1/privacy/policy",
        "http://localhost:3002/api/v1/reviews/vehicle/**",
        "http://127.0.0.1:3002/api/v1/privacy/policy",
        "http://127.0.0.1:3002/api/v1/reviews/vehicle/**"
      ],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "12h",
        "timeout": "10s",
        "strategy": "freshness"
      }
    }
  ],
  "navigationRequestStrategy": "freshness"
}
