{
  "name": "frontend",
  "version": "0.3.0",
  "scripts": {
    "ng": "ng",
    "prestart": "FRONTEND_API_BASE_URL=${FRONTEND_API_BASE_URL:-http://localhost:3000/api/v1} FRONTEND_WS_BASE_URL=${FRONTEND_WS_BASE_URL:-http://localhost:3000} node ./scripts/generate-runtime-config.mjs",
    "start": "ng serve",
    "prebuild": "node ./scripts/generate-runtime-config.mjs",
    "build": "ng build",
    "build:capacitor": "npm run build",
    "cap:copy": "npx cap copy",
    "cap:copy:ios": "npx cap copy ios",
    "cap:sync": "npx cap sync",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "ios:prepare": "npm run build:capacitor && npm run cap:sync:ios",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^16.2.0",
    "@angular/common": "^16.2.0",
    "@angular/compiler": "^16.2.0",
    "@angular/core": "^16.2.0",
    "@angular/forms": "^16.2.0",
    "@angular/platform-browser": "^16.2.0",
    "@angular/platform-browser-dynamic": "^16.2.0",
    "@angular/router": "^16.2.0",
    "@angular/service-worker": "^16.2.12",
    "@capacitor/cli": "^5.7.8",
    "@capacitor/core": "^5.7.8",
    "@capacitor/ios": "^5.7.8",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^16.2.16",
    "@angular/cli": "^16.2.16",
    "@angular/compiler-cli": "^16.2.0",
    "@types/jasmine": "~4.3.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.1.3"
  }
}
