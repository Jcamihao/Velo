{
  "name": "triluga",
  "version": "0.7.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:infra && concurrently -n backend,frontend -c blue,orange \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "dev:backend": "npm --prefix backend run start:dev:prepared",
    "dev:frontend": "FRONTEND_API_BASE_URL=${FRONTEND_API_BASE_URL:-http://localhost:3002/api/v1} FRONTEND_WS_BASE_URL=${FRONTEND_WS_BASE_URL:-http://localhost:3002} npm --prefix frontend run start",
    "ios:prepare": "npm --prefix frontend run ios:prepare",
    "ios:open": "npm --prefix frontend run cap:open:ios",
    "dev:infra": "docker compose up -d --force-recreate postgres redis minio minio-create-bucket",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down -v",
    "db:rebuild": "./scripts/rebuild-postgres.sh",
    "db:seed": "npm --prefix backend run prisma:seed",
    "db:add:cars": "npm --prefix backend run db:add:cars --",
    "backend:prepare": "npm --prefix backend run db:prepare",
    "backend:verify": "npm --prefix backend run verify"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
